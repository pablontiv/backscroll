#!/usr/bin/env bash
# Post-merge: sync skills, rebuild backscroll, propagate doc aggregates

[ -z "$HOME" ] && HOME=$(eval echo ~)

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Install project skills to the Claude user scope.
# Pi is configured by .pi/settings.json to discover ~/.claude/skills.
SKILLS_DEST="$HOME/.claude/skills"
mkdir -p "$SKILLS_DEST"
for skill in backscroll; do
  rm -rf "${SKILLS_DEST:?}/$skill"
  cp -r "$REPO_ROOT/.claude/skills/$skill" "$SKILLS_DEST/$skill"
  echo "backscroll: installed $skill skill → $SKILLS_DEST/$skill"
done

USER_BIN_DIR="${XDG_BIN_HOME:-$HOME/.local/bin}"
echo "Rebuilding backscroll..."
if cargo build --release --manifest-path "$REPO_ROOT/Cargo.toml" 2>&1; then
  mkdir -p "$USER_BIN_DIR"
  cp "$REPO_ROOT/target/release/backscroll" "$USER_BIN_DIR/backscroll"
  chmod +x "$USER_BIN_DIR/backscroll"
  echo "backscroll installed to $USER_BIN_DIR/backscroll"
  if command -v backscroll >/dev/null 2>&1; then
    echo "backscroll available: $(backscroll --version 2>/dev/null || echo 'installed')"
  elif [[ ":$PATH:" != *":$USER_BIN_DIR:"* ]]; then
    echo "Warning: $USER_BIN_DIR is not in PATH; add it to use backscroll globally."
  fi

  # Propagate aggregate values after merge (fix stale parent READMEs)
  rootline fix --all "$REPO_ROOT/docs/epics/" 2>/dev/null || true
else
  echo "Warning: backscroll rebuild failed"
fi
