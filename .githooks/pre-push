#!/usr/bin/env bash
# Pre-push: validate docs, check drift, rebuild binary

remote="$1"
REPO_ROOT="$(git rev-parse --show-toplevel)"

while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  # Validate docs/roadmap/ if changed and directory exists
  if git diff --name-only "$range" -- docs/roadmap/ 2>/dev/null | grep -q . && [ -d docs/roadmap/ ]; then
    echo "Validating docs/roadmap/ before push..."
    if command -v rootline &>/dev/null; then
      if ! rootline validate --all docs/roadmap/ > /dev/null 2>&1; then
        echo "rootline validate --all docs/roadmap/ failed. Fix errors before pushing."
        echo "Run: rootline validate --all docs/roadmap/"
        exit 1
      fi
      echo "docs/roadmap/ validation passed"
    else
      echo "Warning: rootline not installed, skipping docs validation"
    fi
  fi

  # Check if Go source changed but docs weren't updated (test-only changes exempt)
  if git diff --name-only "$range" -- internal/ cmd/ 2>/dev/null | grep -v '_test\.go' | grep -q .; then
    if ! git diff --name-only "$range" -- docs/ README.md CLAUDE.md 2>/dev/null | grep -q .; then
      echo "Go source changed but docs were not updated."
      echo "Update docs/, README.md, or CLAUDE.md before pushing."
      exit 1
    fi
  fi

  # Check if packages were added/removed — requires CLAUDE.md update
  if git diff --diff-filter=AD --name-only "$range" -- 'internal/**/*.go' 'cmd/**/*.go' 2>/dev/null | grep -q .; then
    if ! git diff --name-only "$range" -- CLAUDE.md 2>/dev/null | grep -q .; then
      echo "Package added/removed but CLAUDE.md not updated."
      echo "Update the Module Layout and Package Layout sections in CLAUDE.md."
      exit 1
    fi
  fi

  # Check if CI, install scripts, or build config changed but docs weren't updated
  if git diff --name-only "$range" -- .github/ install.sh install.ps1 Justfile go.mod .goreleaser.yml 2>/dev/null | grep -q .; then
    if ! git diff --name-only "$range" -- README.md docs/ CLAUDE.md 2>/dev/null | grep -q .; then
      echo "CI/scripts/config changed but docs were not updated."
      echo "Update README.md, docs/, or CLAUDE.md before pushing."
      exit 1
    fi
  fi

  # Coverage gate: run pkcov check if Go files changed
  if git diff --name-only "$range" -- '*.go' 2>/dev/null | grep -q .; then
    echo "Checking coverage..."
    if ! just coverage-check > /tmp/backscroll-cov.log 2>&1; then
      cat /tmp/backscroll-cov.log
      echo "Coverage below threshold. Run: just coverage-check"
      exit 1
    fi
    echo "Coverage check passed."
  fi
done

install_input_presets() {
  local config_dir inputs_dest preset dest
  if [ -n "${BACKSCROLL_CONFIG_DIR:-}" ]; then
    config_dir="$BACKSCROLL_CONFIG_DIR"
  elif [ "$(uname -s)" = "Darwin" ]; then
    config_dir="$HOME/Library/Application Support"
  else
    config_dir="${XDG_CONFIG_HOME:-$HOME/.config}"
  fi

  inputs_dest="$config_dir/backscroll/inputs"
  mkdir -p "$inputs_dest"
  for preset in claude.inputs.toml pi.inputs.toml decisions.inputs.toml opencode.inputs.toml; do
    dest="$inputs_dest/$preset"
    if [ -e "$dest" ] && [ "${BACKSCROLL_FORCE_INPUTS:-0}" != "1" ]; then
      echo "backscroll: $dest exists, skipping"
      continue
    fi
    cp "$REPO_ROOT/inputs/$preset" "$dest"
    echo "backscroll: installed input preset → $dest"
  done
}

# Install project skills to the Claude user scope.
SKILLS_DEST="$HOME/.claude/skills"
mkdir -p "$SKILLS_DEST"
for skill in backscroll; do
  rm -rf "${SKILLS_DEST:?}/$skill"
  cp -r "$REPO_ROOT/.claude/skills/$skill" "$SKILLS_DEST/$skill"
  echo "backscroll: installed $skill skill → $SKILLS_DEST/$skill"
done
install_input_presets

# Rebuild backscroll binary so the installed version matches the pushed code.
BACKSCROLL_BIN="${BACKSCROLL_BIN:-$HOME/.local/bin/backscroll}"

install_backscroll_binary() {
  local tmp
  tmp="$(mktemp)"

  local ver
  ver="$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')"
  ver="${ver:-dev}"
  if ! go build -ldflags "-X main.version=${ver}" -o "$tmp" ./cmd/backscroll 2>&1; then
    rm -f "$tmp"
    return 1
  fi

  if [ -w "$BACKSCROLL_BIN" ] || { [ ! -e "$BACKSCROLL_BIN" ] && [ -w "$(dirname "$BACKSCROLL_BIN")" ]; }; then
    install -m 0755 "$tmp" "$BACKSCROLL_BIN"
  elif command -v sudo >/dev/null 2>&1 && sudo -n true 2>/dev/null; then
    sudo install -m 0755 "$tmp" "$BACKSCROLL_BIN"
  else
    echo "Warning: $BACKSCROLL_BIN is not writable and passwordless sudo is unavailable"
    rm -f "$tmp"
    return 1
  fi

  rm -f "$tmp"
}

echo "Rebuilding backscroll..."
if install_backscroll_binary; then
  echo "backscroll rebuilt: $("$BACKSCROLL_BIN" --version 2>/dev/null || echo "unknown")"
  if command -v backscroll >/dev/null 2>&1 && [ "$(command -v backscroll)" != "$BACKSCROLL_BIN" ]; then
    echo "Warning: $(command -v backscroll) shadows $BACKSCROLL_BIN in PATH"
  fi
else
  echo "Warning: backscroll rebuild failed (push continues)"
fi
