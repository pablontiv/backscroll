# Ejemplo de configuración para Backscroll
# Renombra este archivo a backscroll.toml o ponlo en ~/.config/backscroll/config.toml

# Ruta donde se guardará el índice de búsqueda
database_path = "backscroll.db"

# Directorio(s) legacy donde se encuentran sesiones (compatibilidad).
# Puede ser string o array de strings. La clave singular `session_dir` sigue aceptada.
# Una ruta legacy no-default tiene precedencia sobre inputs declarativos.
session_dirs = ["."]
# session_dir = "."

# Inputs declarativos opcionales para parsing de sesiones.
# Pueden vivir aquí, en backscroll.inputs.toml o en backscroll.inputs.d/*.toml.
# La precedencia de paths es: --path > session_dirs no-default > inputs activos > discovery.
# Los manifiestos externos se evalúan en orden: backscroll.inputs.toml y luego
# backscroll.inputs.d/*.toml ordenados por nombre; entradas desconocidas fallan rápido.
[[session_inputs]]
source = "session"
parser = "claude"
paths = ["."]
# Campo reservado para selección declarativa de archivos en el contrato.
glob = "**/*.{json,jsonl}"
include_agents = false
active = true

# Ejemplo opcional de segundo parser (pi). Mantiene source="session" para
# compatibilidad de ingestión; parser selecciona el adapter técnico.
# [[session_inputs]]
# source = "session"
# parser = "pi"
# paths = ["/path/to/pi-events.jsonl"]
# include_agents = false
# active = false
