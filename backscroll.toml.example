# Backscroll application configuration example
# Rename to backscroll.toml or place at ~/.config/backscroll/config.toml.

# Application/database settings belong here.
database_path = "backscroll.db"

[embedding]
model_name = "all-MiniLM-L6-v2"
similarity_threshold = 0.3
top_k = 50
rrf_k = 60

# O02 ingestion routes do NOT live in backscroll.toml.
# Put canonical input manifests in files like claude.inputs.toml,
# pi.inputs.toml, or backscroll.inputs.d/*.toml:
#
# version = 1
#
# [[inputs]]
# id = "claude"
# source = "session"
# active = true
#
# [inputs.discover]
# roots = ["~/.claude/projects"]
# include = ["**/*.jsonl"]
# exclude = ["**/subagents/**"]
#
# [inputs.decode]
# format = "jsonl"
#
# [inputs.map]
# role = "$.message.role"
#
# [inputs.content]
# selector = "$.message.content"

# Legacy migration note: older O01 configs may contain session_dir/session_dirs.
# Those keys are non-canonical in O02 and are not silent canonical input routes.
