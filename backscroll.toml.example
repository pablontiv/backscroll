# Ejemplo de configuración para Backscroll
# Renombra este archivo a backscroll.toml o ponlo en ~/.config/backscroll/config.toml

# Ruta donde se guardará el índice de búsqueda
database_path = "backscroll.db"

# Directorio(es) donde se encuentran sesiones legacy (compatibilidad).
# Puede ser string o array de strings.
session_dirs = ["."]

# Inputs declarativos opcionales para parsing de sesiones.
# Soportan backscroll.inputs.toml y backscroll.inputs.d/*.toml.
# Los manifiestos se evalúan en orden: backscroll.inputs.toml y luego
# backscroll.inputs.d/*.toml ordenados por nombre; entradas desconocidas fallan rápido.
[[session_inputs]]
source = "session"
parser = "claude"
paths = ["."]
# Campo reservado para selección declarativa de archivos en el contrato.
glob = "**/*.{json,jsonl}"
include_agents = false
active = true

# Ejemplo opcional de segundo parser (pi)
# [[session_inputs]]
# source = "session"
# parser = "pi"
# paths = ["/path/to/pi-events.jsonl"]
# include_agents = false
# active = false
