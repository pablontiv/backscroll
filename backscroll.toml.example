# Backscroll application configuration example
# Rename to backscroll.toml or place at ~/.config/backscroll/config.toml.

# Application/database settings belong here.
database_path = "backscroll.db"

[embedding]
model_name = "all-MiniLM-L6-v2"
similarity_threshold = 0.3
top_k = 50
rrf_k = 60

# Input manifests do NOT live in backscroll.toml.
# Canonical ingestion config is global/user-scoped:
#   <config_dir>/backscroll/inputs/*.inputs.toml
# where <config_dir> is:
#   Linux:  ${XDG_CONFIG_HOME:-$HOME/.config}
#   macOS:  $HOME/Library/Application Support
#   Windows: %APPDATA%
# or BACKSCROLL_CONFIG_DIR when set.
#
# Copy shipped presets such as inputs/claude.inputs.toml and
# inputs/pi.inputs.toml into that directory, preserving existing files
# by default so local edits are not overwritten.
#
# Example input manifest content (in <config_dir>/backscroll/inputs/claude.inputs.toml):
#
# version = 1
#
# [[inputs]]
# id = "claude"
# source = "session"
# active = true
#
# [inputs.discover]
# roots = ["~/.claude/projects"]
# include = ["**/*.jsonl"]
# exclude = ["**/subagents/**"]
#
# [inputs.decode]
# format = "jsonl"
#
# [inputs.map]
# role = "$.message.role"
#
# [inputs.content]
# selector = "$.message.content"

# Legacy migration note: older app configs may contain session_dir/session_dirs
# or [sources] route settings. Those keys are historical compatibility config,
# not canonical input routes.
