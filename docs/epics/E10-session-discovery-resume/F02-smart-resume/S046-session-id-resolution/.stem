version: 2
schema:
  id:
    type: sequence
    match:
      "T*": {prefix: T, digits: 3}
  estado:
    type: enum
    values: [Pending, Specified, In Progress, Completed, Blocked, On Hold, Obsolete]
    default: Pending
  tipo:
    type: enum
    values: [code, test, refactor, chore, docs]
    default: code
  ejecutable_en:
    type: string
    default: "1 sesion"
